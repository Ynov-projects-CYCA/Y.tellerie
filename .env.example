COMPOSE_PROJECT_NAME=ytellerie

FRONTEND_PORT=4200
BACKEND_PORT=3000
PGADMIN_PORT=5050

NODE_ENV=production
POSTGRES_HOST=postgres
POSTGRES_DB=hotel_db
POSTGRES_USER=hotel_user
POSTGRES_PASSWORD=hotel_pass

JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

CORS_ALLOWED_ORIGINS=http://localhost:4200

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEFAULT_CURRENCY=usd
STRIPE_SUCCESS_URL=http://localhost:4200/client/paiement/success
STRIPE_CANCEL_URL=http://localhost:4200/client/paiement/cancel

MAILJET_API_KEY=
MAILJET_API_SECRET=
MAILJET_SANDBOX=true
MAILJET_SENDER_EMAIL=
MAILJET_SENDER_NAME=Archi Hotel

PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
